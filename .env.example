# ─────────────────────────────────────────────
# Impact Studio AI Migration — Environment Vars
# Copy this file to .env.local for local dev
# Add these same keys in Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────

# Resend API Key — get from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The email address intake submissions get sent TO
INTAKE_TO_EMAIL=tamar@podcastimpactstudio.com

# The FROM address — must be a verified domain in Resend
INTAKE_FROM_EMAIL=migration@podcastimpactstudio.com
